        "nodemailer": "^6.10.1"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "jest": "^29.7.0",
        "supertest": "^6.3.0"
    },
    "jest": {
        "testEnvironment": "node",
        "coverageDirectory": "coverage",
        "testMatch": ["**/tests/**/*.test.js"]
    }
