{
  "name": "sparkaudit-compliance-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"wait-on http://localhost:3001/api/data && vite\"",
    "server": "node --env-file=.env.production server/server.js",
    "build": "vite build",
    "preview": "vite preview",
    "build:prod": "npm install --include=dev && vite build && cd server && npm install",
    "start": "cd server && npm start"
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "terser": "^5.48.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
