# Production Environment Variables
# Copy this file to .env.production and fill in the values

# Server Configuration
NODE_ENV=production
PORT=3001

# Frontend API Base URL (update after deployment)
VITE_API_BASE_URL=https://your-domain.com

# Database (SQLite - no changes needed for file-based)
# For production, consider using PostgreSQL/MySQL

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Security
SESSION_SECRET=generate-a-strong-random-secret-here

# Gemini AI API (if used)
GEMINI_API_KEY=your-gemini-api-key
